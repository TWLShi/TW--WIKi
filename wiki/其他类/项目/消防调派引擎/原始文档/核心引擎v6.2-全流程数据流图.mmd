    classDef ai fill:#a855f7,stroke:#6b21a8,color:#fff,stroke-width:3px
    classDef human fill:#3b82f6,stroke:#1e40af,color:#fff,stroke-width:4px
    classDef end fill:#ef4444,stroke:#991b1b,color:#fff,stroke-width:4px
    classDef input fill:#64748b,stroke:#475569,color:#fff,stroke-width:2px
    classDef output fill:#22d3ee,stroke:#164e63,color:#000,stroke-width:2px
    classDef loop fill:#f97316,stroke:#c2410c,color:#fff,stroke-width:2px

    class Start start
    class S1,S2,S3,S4,S5,S6,S7,S8,S11 step
    class S9 ai
    class S10 human
    class S12 end
    class In1,In2,In3,In4,In5,In6,In7,In8,In9,In10,In11,In12 input
    class Out1,Out2,Out3,Out4,Out5,Out6,Out7,Out8,Out9,Out10,Out11,Out12 output
    class Back1,Back2,Back3 loop